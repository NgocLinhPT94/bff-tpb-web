# =============================================================================
# tpb-web-bff Environment Variables
# =============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env with real credentials to source control.
# Production values are managed via External Secrets Operator -> Vault/CyberArk.
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3001
APP_NAME=tpb-web-bff
ENABLE_SWAGGER=false

# --- Database (PostgreSQL) --- [PLANNED/FUTURE]
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=tpb_user
# DB_PASSWORD=change_me_db_password
# DB_NAME=tpb_bff_dev

# --- Redis --- [PLANNED/FUTURE]
# REDIS_HOST=localhost
# REDIS_PORT=6379

# --- CMS (Strapi) ---
# Docker: http://cms:1337 | Local: http://localhost:1337
CMS_BASE_URL=http://localhost:1337
CMS_API_TOKEN=change_me_cms_api_token
CMS_TIMEOUT=5000
CMS_RETRY_ATTEMPTS=1

# --- Core Bank Integration ---
CORE_BANK_BASE_URL=http://localhost:8080/api/core-bank
CORE_BANK_API_KEY=change_me_core_bank_api_key
CORE_BANK_TIMEOUT=5000

# --- CRM Integration ---
CRM_BASE_URL=http://localhost:8081/api/crm
CRM_API_KEY=change_me_crm_api_key
CRM_TIMEOUT=5000

# --- SMS Gateway ---
SMS_GATEWAY_BASE_URL=http://localhost:8082/api/sms
SMS_GATEWAY_API_KEY=change_me_sms_api_key
SMS_GATEWAY_SENDER_ID=TPBank
SMS_GATEWAY_TIMEOUT=5000

# --- reCAPTCHA ---
RECAPTCHA_SECRET_KEY=change_me_recaptcha_secret
RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
RECAPTCHA_SCORE_THRESHOLD=0.5

# --- OTP ---
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3

# --- Rate Limiting ---
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Logging ---
LOG_LEVEL=debug

# --- Preview Mode (shared secret between FE and BFF) ---
FE_INTERNAL_SECRET=
